{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "rootDir": "gpt2giga/frontend",
    "outDir": "packages/gpt2giga-ui/src/gpt2giga_ui/static",
    "verbatimModuleSyntax": true
  },
  "include": ["gpt2giga/frontend/**/*.ts"]
}

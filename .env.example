# ==============================================================================
# gpt2giga — пример конфигурации
# ==============================================================================
# Скопируйте этот файл в .env и укажите реальные значения.
#
#   cp .env.example .env
#
# Docker Compose:
# - сервисы в `docker-compose.yaml` включаются через профили `DEV`/`PROD`
# - запуск: `docker compose --profile PROD up -d` (или `--profile DEV`)
#
# ВАЖНО: Для production-среды обязательно:
#   - установите GPT2GIGA_MODE=PROD
#   - включите GPT2GIGA_ENABLE_API_KEY_AUTH=True и задайте надёжный API ключ
#   - установите GIGACHAT_VERIFY_SSL_CERTS=True
#   - ограничьте CORS origins вместо wildcard ["*"]
#
# ==============================================================================
# Чеклист по безопасной эксплуатации (production)
# ==============================================================================
# 1. GPT2GIGA_MODE=PROD                 — отключает /docs, /logs*, подробный вывод
# 2. GPT2GIGA_ENABLE_API_KEY_AUTH=True  — включает API-key на всех эндпоинтах
# 3. GPT2GIGA_API_KEY=<сильный секрет>  — минимум 32 случайных символа
# 4. GIGACHAT_VERIFY_SSL_CERTS=True     — проверяет TLS сертификаты до API GigaChat
# 5. GPT2GIGA_CORS_ALLOW_ORIGINS=["https://your-app.example.com"]
# 6. GPT2GIGA_LOG_REDACT_SENSITIVE=True (по умолчанию) — маскирует секреты в логах
# 7. GPT2GIGA_LOG_LEVEL=INFO            — избегайте DEBUG в production
# 8. GPT2GIGA_MAX_REQUEST_BODY_BYTES=10485760 — ограничение тела запроса (10 МБ)
# 9. Запускайте за reverse proxy (nginx/Caddy) с TLS termination
# ==============================================================================

# --- Настройки прокси ---------------------------------------------------------
GPT2GIGA_MODE=DEV
GPT2GIGA_HOST=0.0.0.0
GPT2GIGA_PORT=8090
GPT2GIGA_LOG_LEVEL=INFO
GPT2GIGA_ENABLE_API_KEY_AUTH=True
GPT2GIGA_API_KEY="<REPLACE_WITH_STRONG_SECRET>"
# Отключает HTML admin UI даже если установлен optional пакет gpt2giga-ui.
# GPT2GIGA_DISABLE_UI=false

# Полностью отключает persistent control-plane storage.
# При true runtime читает конфиг только из .env и ENV переменных процесса/контейнера,
# а admin save/rollback/key rotation mutations становятся недоступны.
# Полезно для Docker/12-factor deployments, где source of truth живёт только в env.
# GPT2GIGA_DISABLE_PERSIST=false

# Опциональные scoped API keys для отдельных клиентов/интеграций.
# Формат: JSON-массив. Global GPT2GIGA_API_KEY сохраняет полный доступ,
# а scoped keys можно ограничить по provider, endpoint и model.
# Endpoint ids указываются без /v1 или /v1beta.
# Пример:
# GPT2GIGA_SCOPED_API_KEYS=[{"name":"sdk-openai","key":"<REPLACE_WITH_SCOPED_SECRET>","providers":["openai"],"endpoints":["chat/completions"],"models":["GigaChat-2-Max"]}]

# Опциональные governance rules для fixed-window rate limits и token quotas.
# Поддерживаются scope:
# - api_key
# - provider
# Optional filters:
# - providers
# - endpoints
# - models
# Порог можно задать по max_requests и/или max_total_tokens.
# Пример:
# GPT2GIGA_GOVERNANCE_LIMITS=[{"name":"openai-burst","scope":"api_key","providers":["openai"],"endpoints":["chat/completions"],"window_seconds":60,"max_requests":30},{"name":"openai-provider-quota","scope":"provider","providers":["openai"],"models":["GigaChat-2-Max"],"window_seconds":3600,"max_total_tokens":200000}]

# Список внешних провайдеров, которые нужно включить при старте.
# Поддерживаются: openai, anthropic, gemini
# Значение all включает все провайдеры.
# LiteLLM-совместимый /model/info включается вместе с openai.
# GPT2GIGA_ENABLED_PROVIDERS=openai,gemini

# Режим backend API GigaChat:
# - v1: chat/completions, Anthropic/Gemini chat-like path и batch chat идут через achat/astream
# - v2: эти capability идут через achat_v2/astream_v2 там, где это поддержано
# GPT2GIGA_GIGACHAT_API_MODE=v1

# Опциональный override только для OpenAI /responses.
# Пусто = наследовать GPT2GIGA_GIGACHAT_API_MODE.
# GPT2GIGA_GIGACHAT_RESPONSES_API_MODE=v2

# Runtime backend для metadata stores и recent audit feeds.
# Встроенные значения:
# - memory: process-local ring buffers и dict stores
# - sqlite: durable/queryable SQLite backend
# Если выбран sqlite, можно указать путь как обычный file path или sqlite:///absolute/path.db.
# Без GPT2GIGA_RUNTIME_STORE_DSN будет создан локальный файл
# .gpt2giga-runtime-<namespace>.sqlite3 в текущей директории процесса.
# GPT2GIGA_RUNTIME_STORE_BACKEND=memory
# GPT2GIGA_RUNTIME_STORE_DSN=sqlite:///tmp/gpt2giga-runtime.db
# GPT2GIGA_RUNTIME_STORE_NAMESPACE=gpt2giga

# Включить sink telemetry layer поверх normalized request events.
# False отключает fan-out в Prometheus/OTLP/Langfuse/Phoenix, но сохраняет
# recent request/error feeds для /admin.
# GPT2GIGA_ENABLE_TELEMETRY=true

# Observability sinks для нормализованных request events.
# Встроенные sink-и: prometheus, otlp, langfuse, phoenix.
# Пустое значение / none отключает metrics exporter.
# GPT2GIGA_OBSERVABILITY_SINKS=prometheus

# Полный OTLP/HTTP traces endpoint.
# Для OpenTelemetry Collector обычно: http://otel-collector:4318/v1/traces
# GPT2GIGA_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces

# Дополнительные OTLP headers: JSON object или CSV Header=Value.
# GPT2GIGA_OTLP_HEADERS={"Authorization":"Bearer token"}
# GPT2GIGA_OTLP_HEADERS=Authorization=Bearer token,X-Scope-OrgID=tenant-a

# Тюнинг встроенного OTLP/Langfuse/Phoenix exporter-а.
# GPT2GIGA_OTLP_TIMEOUT_SECONDS=5
# GPT2GIGA_OTLP_MAX_PENDING_REQUESTS=256
# GPT2GIGA_OTLP_SERVICE_NAME=gpt2giga

# Настройки встроенного Langfuse sink-а.
# Base URL без суффикса /api/public/otel/v1/traces.
# GPT2GIGA_LANGFUSE_BASE_URL=http://langfuse-web:3000
# GPT2GIGA_LANGFUSE_PUBLIC_KEY=pk-lf-...
# GPT2GIGA_LANGFUSE_SECRET_KEY=sk-lf-...

# Настройки встроенного Phoenix sink-а.
# Base URL без суффикса /v1/traces.
# Для self-hosted Phoenix по умолчанию: http://phoenix:6006
# GPT2GIGA_PHOENIX_BASE_URL=http://phoenix:6006
# GPT2GIGA_PHOENIX_API_KEY=phx-...
# GPT2GIGA_PHOENIX_PROJECT_NAME=gpt2giga

# Включить reasoning по умолчанию (добавляет reasoning_effort="high" в запросы к GigaChat,
# если клиент не указал reasoning_effort явно).
# GPT2GIGA_ENABLE_REASONING=False

# Глобальный лимит размера HTTP-тела запроса (в байтах, по умолчанию 10 МБ).
# GPT2GIGA_MAX_REQUEST_BODY_BYTES=10485760

# CORS списки в формате JSON-массивов:
# В production ограничьте origins конкретными доменами.
# GPT2GIGA_CORS_ALLOW_ORIGINS=["https://your-app.example.com"]
# GPT2GIGA_CORS_ALLOW_METHODS=["GET","POST","OPTIONS"]
# GPT2GIGA_CORS_ALLOW_HEADERS=["authorization","content-type","x-api-key"]

# IP allowlist для /logs* (пусто = без ограничений, недоступно в PROD)
# GPT2GIGA_LOGS_IP_ALLOWLIST=["10.0.0.1"]

# Доверенные reverse proxy IP/CIDR, от которых разрешено учитывать
# X-Forwarded-For. По умолчанию forwarded headers игнорируются.
# GPT2GIGA_TRUSTED_PROXY_CIDRS=["127.0.0.1/32"]

# --- Настройки GigaChat -------------------------------------------------------
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_CREDENTIALS="<REPLACE_WITH_YOUR_GIGACHAT_CREDENTIALS>"
#GIGACHAT_USER=
#GIGACHAT_PASSWORD=
GIGACHAT_PROFANITY_CHECK=False
GIGACHAT_MODEL=GigaChat-2-Max
# Если upstream TLS подписан корпоративным или self-signed CA, укажите путь
# к PEM bundle внутри контейнера/процесса и оставьте verify включенным.
# Пример для Docker Compose: смонтируйте ./certs в /certs и используйте
# GIGACHAT_CA_BUNDLE_FILE=/certs/company-root.pem
#GIGACHAT_CA_BUNDLE_FILE=/certs/company-root.pem
GIGACHAT_VERIFY_SSL_CERTS=False
GIGACHAT_TIMEOUT=70000


# --- Настройки mitmproxy -------------------------------------------------------
#HTTPS_PROXY="http://mitmproxy:8080"
#HTTP_PROXY="http://mitmproxy:8080"
#MITMPROXY_PASSWORD=12345
